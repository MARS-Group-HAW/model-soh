        </Content>
        <Content Include="config_PreComputeRoutes.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="resources\*.*">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Update="resources\Scripts\SemiTruckData\NUTS_RG_01M_2024_4326.shp">
