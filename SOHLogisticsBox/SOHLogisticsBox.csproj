        </Content>
        <Content Update="resources\Scripts\SemiTruckData\referenzhandbuch_VD_2V.pdf">
          <Link>resources\Scripts\SemiTruckData\resources\referenzhandbuch_VD_2V.pdf</Link>
        </Content>
