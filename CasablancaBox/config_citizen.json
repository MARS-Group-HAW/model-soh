{
  "id": "casa_citizen",
  "globals": {
    "startPoint": "2025-01-01T07:00:00",
    "endPoint": "2025-01-01T10:00:00",
    "deltaT": 1,
    "deltaTUnit": "seconds",
    "console": true,
    "csvOptions": {
      "outputPath": "results"
    }
  },
  "agents": [
    {
      "name": "Citizen",
      "count": 50,
      "inputs": [
        {
          "file": "resources/citizen_init_10k.csv"
        }
      ],
      "individual": [
        {
          "parameter": "ResultTrajectoryEnabled",
          "value": true
        },
        {
          "parameter": "CapabilityBus",
          "value": true
        },
        {
          "parameter": "CapabilityTram",
          "value": true
        },
        {
          "parameter": "CapabilityCycling",
          "value": true
        }
      ],
      "outputs": [
        {
          "kind": "trips",
          "outputConfiguration": {
            "tripsFields": [
              "StableId",
              "ActiveCapability",
              "RouteMainModality",
              "RouteModalities"
            ]
          }
        },
        {
          "kind": "default"
        }
      ],
      "outputFilter": [
        {
          "parameter": "StoreTickResult",
          "operator": "in",
          "values": [
            true
          ]
        }
      ]
    },
    {
      "name": "BusDriver",
      "outputs": [
        {
          "kind": "trips",
          "outputConfiguration": {
            "fileSuffix": "BusDriver",
            "tripsFields": [
              "StableId",
              "Line",
              "PassengerAmount"
            ]
          }
        },
        {
          "kind": "default"
        }
      ]
    },
    {
      "name": "TramDriver",
      "outputs": [
        {
          "kind": "trips",
          "outputConfiguration": {
            "fileSuffix": "TramDriver",
            "tripsFields": [
              "StableId",
              "Line",
              "PassengerAmount"
            ]
          }
        },
        {
          "kind": "default"
        }
      ]
    }
  ],
  "layers": [
    {
      "name": "VectorBuildingsLayer",
      "file": "resources/casa_buildings.geojson"
    },
    {
      "name": "VectorLanduseLayer",
      "file": "resources/casa_landuse.geojson"
    },
    {
      "name": "VectorPoiLayer",
      "file": "resources/casa_sidi_maarouf_pois_clean.geojson"
    },
    {
      "name": "SpatialGraphMediatorLayer",
      "inputs": [
        {
          "file": "resources/casa_sidi_maarouf_walk_graph.geojson",
          "inputConfiguration": {
            "modalities": [
              "Walking"
            ],
            "isBidirectedGraph": true
          }
        },
        {
          "file": "resources/casablanca_T1_graph.geojson",
          "inputConfiguration": {
            "modalities": [
              "TrainDriving"
            ],
            "isBidirectedGraph": true
          }
        },
        {
          "file": "resources/casa_sidi_maarouf_drive_graph.geojson",
          "inputConfiguration": {
            "modalities": [
              "CarDriving",
              "Cycling"
            ],
            "isBidirectedGraph": true,
            "noHelperNodes": true
          }
        }
      ]
    },
    {
      "file": "resources/bicycle_rental_sidi_maarouf.geojson",
      "name": "BicycleRentalLayer"
    },
    {
      "name": "BusStationLayer",
      "file": "resources/stations.geojson"
    },
    {
      "name": "BusRouteLayer",
      "file": "resources/bus_L300_line.csv"
    },
    {
      "name": "BusLayer",
      "file": "resources/casa_sidi_maarouf_drive_graph.geojson"
    },
    {
      "name": "CitizenLayer"
    },
    {
      "name": "BusSchedulerLayer",
      "file": "resources/bus_driver_schedule_casablanca.csv"
    },
    {
      "name": "TramStationLayer",
      "file": "resources/casablanca_T1_stations.geojson"
    },
    {
      "name": "TramRouteLayer",
      "file": "resources/tram_t1_line.csv"
    },
    {
      "name": "TramLayer",
      "file": "resources/casa_sidi_maarouf_walk_graph.geojson"
    },
    {
      "name": "TramSchedulerLayer",
      "file": "resources/tram_driver_schedule.csv"
    }
  ],
  "entities": [
    {
      "file": "resources/bicycle.csv",
      "name": "RentalBicycle"
    },
    {
      "name": "Bus",
      "file": "resources/bus.csv"
    },
    {
      "name": "Tram",
      "file": "resources/tram.csv"
    }
  ]
}